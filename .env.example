# Copy this file to .env for local development (.env is git-ignored).
# In production, set these in Vercel → Settings → Environment Variables.

# Login credentials for the app
AUTH_USER=changeme
AUTH_PASS=changeme

# Provided automatically by Vercel Blob when you connect a Blob store.
# Only needed locally if you want to test /api/data against Vercel Blob.
# BLOB_READ_WRITE_TOKEN=
